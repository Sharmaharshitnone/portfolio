---
/**
 * Navbar — Astro shell component.
 * Mobile toggle + scroll shadow handled via hoisted <script>.
 * Active path resolved server-side from Astro.url.pathname.
 */
import { NAV_LINKS } from "../../lib/constants";

const currentPath = Astro.url.pathname;
---

<header
    id="site-nav"
    class="fixed top-0 left-0 w-full z-50 h-14 border-b border-border backdrop-blur-sm transition-all duration-200"
    style="background-color: color-mix(in srgb, var(--bg) 80%, transparent);"
>
    <div class="container h-full flex items-center justify-between">
        <a
            href="/"
            class="font-mono text-[13px] font-semibold tracking-tight text-foreground hover:text-dim transition-colors"
            aria-label="Harshit Sharma — Home"
        >
 	   Harshit.Systems
        </a>

        <div class="flex items-center gap-1">
            <!-- Desktop nav links (hidden on mobile) -->
            <nav class="hidden md:flex items-center gap-0.5" aria-label="Main navigation">
                {NAV_LINKS.map((link) => {
                    const isActive = link.href === "/"
                        ? currentPath === "/"
                        : currentPath.startsWith(link.href);
                    return (
                        <a
                            href={link.href}
                            aria-current={isActive ? "page" : undefined}
                            class:list={[
                                "text-[13px] px-3 py-1.5 rounded-md transition-colors",
                                isActive
                                    ? "text-foreground font-medium"
                                    : "text-dim hover:text-subtle",
                            ]}
                        >
                            {link.label}
                        </a>
                    );
                })}
            </nav>

            <!-- Divider (desktop only) -->
            <div class="hidden md:block w-px h-5 bg-border mx-1.5" aria-hidden="true"></div>

            <!-- SearchBar + ThemeToggle (always visible) -->
            <div class="flex items-center gap-1">
                <slot name="nav-right" />
            </div>

            <!-- Mobile hamburger -->
            <button
                id="mobile-menu-btn"
                class="md:hidden p-2.5 text-dim hover:text-foreground transition-colors"
                aria-label="Open navigation menu"
                aria-expanded="false"
                aria-controls="mobile-nav"
            >
                <svg id="icon-menu" class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <line x1="4" x2="20" y1="12" y2="12"></line>
                    <line x1="4" x2="20" y1="6" y2="6"></line>
                    <line x1="4" x2="20" y1="18" y2="18"></line>
                </svg>
                <svg id="icon-close" class="h-5 w-5 hidden" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M18 6 6 18"></path>
                    <path d="m6 6 12 12"></path>
                </svg>
            </button>
        </div>
    </div>

    <div
        id="mobile-nav"
        role="region"
        aria-label="Mobile navigation"
        class="md:hidden absolute top-14 left-0 w-full bg-background border-b border-border max-h-0 opacity-0 overflow-hidden transition-[max-height,opacity] duration-200"
        aria-hidden="true"
    >
        <nav class="px-5 py-4 flex flex-col gap-1">
            {NAV_LINKS.map((link) => {
                 const isActive = link.href === "/"
                    ? currentPath === "/"
                    : currentPath.startsWith(link.href);
                return (
                    <a
                        href={link.href}
                        aria-current={isActive ? "page" : undefined}
                        class:list={[
                            "text-[15px] px-3 py-3 rounded-md transition-colors",
                            isActive
                                ? "text-foreground bg-surface font-medium"
                                : "text-foreground hover:bg-surface",
                        ]}
                    >
                        {link.label}
                    </a>
                );
            })}
        </nav>
    </div>
</header>

<script>
    /**
     * Smart Navbar — AbortController pattern for View Transitions.
     *
     * Problem: astro:page-load fires on every navigation. Each call to
     * setupNav used to add a NEW scroll listener on `window` without
     * removing the old one. After N navigations → N stale listeners
     * referencing detached DOM nodes.
     *
     * Fix: A module-level AbortController is .abort()-ed before each
     * re-initialisation, tearing down ALL prior listeners in one shot.
     */
    let navController: AbortController | null = null;

    function setupNav() {
        // ── Tear down previous listeners ──
        if (navController) navController.abort();
        navController = new AbortController();
        const { signal } = navController;

        const btn = document.getElementById("mobile-menu-btn") as HTMLElement;
        const panel = document.getElementById("mobile-nav") as HTMLElement;
        const iconMenu = document.getElementById("icon-menu") as HTMLElement;
        const iconClose = document.getElementById("icon-close") as HTMLElement;
        const header = document.getElementById("site-nav") as HTMLElement;

        if (!btn || !panel || !iconMenu || !iconClose || !header) return;

        // ── Reset mobile menu state on navigation ──
        let isOpen = false;
        panel.classList.add("max-h-0", "opacity-0");
        panel.classList.remove("max-h-[320px]", "opacity-100");
        panel.setAttribute("aria-hidden", "true");
        btn.setAttribute("aria-expanded", "false");
        iconMenu.classList.remove("hidden");
        iconClose.classList.add("hidden");

        // ── Reset navbar position (visible, no shadow if at top) ──
        header.style.transform = "translateY(0)";
        if (window.scrollY <= 0) header.classList.remove("shadow-sm");

        // ── Mobile menu toggle ──
        btn.addEventListener("click", () => {
            isOpen = !isOpen;
            panel.classList.toggle("max-h-0", !isOpen);
            panel.classList.toggle("opacity-0", !isOpen);
            panel.classList.toggle("max-h-[320px]", isOpen);
            panel.classList.toggle("opacity-100", isOpen);
            panel.setAttribute("aria-hidden", String(!isOpen));
            btn.setAttribute("aria-expanded", String(isOpen));
            btn.setAttribute("aria-label", isOpen ? "Close navigation menu" : "Open navigation menu");
            iconMenu.classList.toggle("hidden", isOpen);
            iconClose.classList.toggle("hidden", !isOpen);
        }, { signal });

        // ── Smart scroll: hide ↓, show ↑ ──
        let lastScrollY = window.scrollY;
        let ticking = false;
        const THRESHOLD = 10; // px dead-zone

        function onScroll() {
            const y = window.scrollY;
            const delta = y - lastScrollY;

            if (y <= 0) {
                header.style.transform = "translateY(0)";
                header.classList.remove("shadow-sm");
                lastScrollY = y;
            } else if (delta > THRESHOLD) {
                // Scrolling DOWN → hide
                header.style.transform = "translateY(-100%)";
                lastScrollY = y;
                if (isOpen) {
                    isOpen = false;
                    panel.classList.add("max-h-0", "opacity-0");
                    panel.classList.remove("max-h-[320px]", "opacity-100");
                    panel.setAttribute("aria-hidden", "true");
                    btn.setAttribute("aria-expanded", "false");
                    iconMenu.classList.remove("hidden");
                    iconClose.classList.add("hidden");
                }
            } else if (delta < -THRESHOLD) {
                // Scrolling UP → show
                header.style.transform = "translateY(0)";
                header.classList.add("shadow-sm");
                lastScrollY = y;
            }
            // Dead-zone: don't update lastScrollY so small movements accumulate

            ticking = false;
        }

        window.addEventListener("scroll", () => {
            if (!ticking) {
                requestAnimationFrame(onScroll);
                ticking = true;
            }
        }, { passive: true, signal });
    }

    // Fires on initial load AND after every View Transition navigation.
    document.addEventListener("astro:page-load", setupNav);
</script>
