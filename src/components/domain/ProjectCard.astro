---
/**
 * ProjectCard — Domain-specific card for project listings.
 * Zero JS. Typed via content collection schema.
 */
import Badge from "../ui/Badge.astro";
import Card from "../ui/Card.astro";

interface Props {
    title: string;
    description: string;
    category: string;
    techStack: string[];
    githubUrl: string;
    liveUrl?: string;
    pubDate: Date;
    href: string;
    class?: string;
}

const {
    title,
    description,
    category,
    techStack,
    githubUrl,
    liveUrl,
    pubDate,
    href,
    class: className,
} = Astro.props;
---

<a href={href} class="block group">
    <Card class={`p-5 flex flex-col ${className ?? ""}`}>
        <div class="flex justify-between items-start mb-3">
            <span class="text-xs font-mono text-dim uppercase tracking-wider">
                {category}
            </span>
            <span class="text-xs font-mono text-faint">
                {pubDate.toISOString().slice(0, 10)}
            </span>
        </div>

        <h3 class="text-foreground font-medium mb-2 group-hover:text-subtle transition-colors">
            {title}
        </h3>

        <p class="text-dim text-sm line-clamp-2 mb-6 flex-1">
            {description}
        </p>

        <div class="flex flex-wrap gap-2 mb-6">
            {techStack.slice(0, 4).map((tech) => (
                <Badge variant="default">{tech}</Badge>
            ))}
        </div>

        <div class="pt-4 border-t border-border flex items-center gap-4 mt-auto">
            <span class="text-dim text-[13px] inline-flex items-center gap-1.5" onclick={`event.preventDefault();event.stopPropagation();window.open('${githubUrl}','_blank')`}>
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
                Source
            </span>
            {liveUrl && (
                <span class="text-dim text-[13px] inline-flex items-center gap-1.5">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
                    Demo
                </span>
            )}
        </div>
    </Card>
</a>
