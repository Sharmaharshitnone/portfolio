---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/ui/SectionHeading.astro";
import { ContactForm } from "../components/islands/ContactForm";
import { CONTACT_LINKS } from "../lib/constants";
---

<BaseLayout title="Contact — Harshit Sharma">
    <div class="container py-20 sm:py-32">
        <SectionHeading text="Contact" class="mb-4" />
        <p class="text-dim text-[15px] max-w-2xl mb-16 sm:mb-24">
            I'm always interested in hearing about new projects, opportunities,
            or just chatting about distributed systems and Rust.
        </p>

        <div class="grid lg:grid-cols-2 gap-20 lg:gap-32">
            <!-- Contact Form Island — hydrates when visible -->
            <ContactForm client:visible />

            {/* Info Panel */}
            <div class="flex flex-col gap-10">
                <div class="space-y-6">
                    {
                        CONTACT_LINKS.map((link) => (
                            <div class="flex items-center justify-between group">
                                <div class="flex items-center gap-4">
                                    <span class="text-faint group-hover:text-dim transition-colors" aria-hidden="true">
                                        <Fragment set:html={link.svg} />
                                    </span>
                                    <span class="text-[11px] font-mono uppercase text-dim">
                                        {link.label}
                                    </span>
                                </div>
                                {link.href ? (
                                    <a
                                        href={link.href}
                                        target={
                                            link.href.startsWith("http")
                                                ? "_blank"
                                                : undefined
                                        }
                                        rel={
                                            link.href.startsWith("http")
                                                ? "noopener noreferrer"
                                                : undefined
                                        }
                                        class="text-subtle text-[15px] hover:text-foreground transition-colors flex items-center gap-1"
                                    >
                                        {link.value}
                                        {link.href.startsWith("http") && (
                                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-faint" aria-hidden="true"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
                                        )}
                                    </a>
                                ) : (
                                    <span class="text-subtle text-[15px]">
                                        {link.value}
                                    </span>
                                )}
                            </div>
                        ))
                    }
                </div>

                <div class="pt-10 border-t border-border mt-auto">
                    <p class="text-dim text-[13px]">
                        Currently open to opportunities starting Q3 2026.
                    </p>
                </div>
            </div>
        </div>
    </div>
</BaseLayout>
