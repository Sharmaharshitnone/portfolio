---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/sections/Hero.astro";
import FeaturedProjects from "../components/sections/FeaturedProjects.astro";
import SkillsGrid from "../components/sections/SkillsGrid.astro";
import RecentLogs from "../components/sections/RecentLogs.astro";
import SectionHeading from "../components/ui/SectionHeading.astro";
import Badge from "../components/ui/Badge.astro";
import Button from "../components/ui/Button.astro";
import AlgorithmRow from "../components/domain/AlgorithmRow.astro";
import { STATS } from "../lib/constants";
import { getCollection } from "astro:content";

const allAlgorithms = await getCollection("algorithms");
const recentAlgorithms = allAlgorithms
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 5);
---

<BaseLayout title="Harshit Sharma — Systems Engineer">
	<Hero />

	{/* Stats */}
	<section
		aria-label="Quick statistics"
		class="container pb-24 sm:pb-36 flex flex-wrap justify-start gap-x-10 gap-y-4"
	>
		{
			STATS.map((stat) => (
				<div class="flex items-baseline">
					<span class="font-mono text-foreground text-lg">
						{stat.value}
					</span>
					<span class="text-faint text-sm ml-2">{stat.label}</span>
				</div>
			))
		}
	</section>

	<FeaturedProjects />
	<SkillsGrid />

	{/* Recent Problems */}
	<section
		aria-labelledby="problems-heading"
		class="container pb-24 sm:pb-36"
	>
		<div class="flex items-center justify-between mb-8">
			<SectionHeading id="problems-heading" text="Recent Problems" />
			<a
				href="/algorithms"
				class="text-faint hover:text-dim text-sm inline-flex items-center gap-1 transition-colors"
			>
				All problems
				<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
			</a>
		</div>

		<div class="border border-border rounded-md bg-card overflow-hidden">
			{
				recentAlgorithms.map((problem, i) => (
					<AlgorithmRow
						title={problem.data.title}
						platform={problem.data.platform}
						difficulty={problem.data.difficulty}
						tags={problem.data.tags}
						pubDate={problem.data.pubDate}
						href={`/algorithms/${problem.id}`}
						isFirst={i === 0}
					/>
				))
			}
		</div>
	</section>

	<RecentLogs />

	{/* CTA */}
	<section aria-labelledby="cta-heading" class="container pb-28 sm:pb-40">
		<SectionHeading
			id="cta-heading"
			text="Let's work together"
			class="mb-4"
		/>
		<p class="text-dim text-sm mb-8 max-w-md">
			Open to collaborations on systems programming, distributed systems,
			and open source infrastructure.
		</p>
		<div class="flex items-center gap-4">
			<a href="mailto:harshit@systems.dev">
				<Button variant="inverted" class="gap-2">
					Get in touch
					<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
				</Button>
			</a>
			<a
				href="https://github.com/sharmaharshitnone"
				target="_blank"
				rel="noopener noreferrer"
			>
				<Button variant="outline" class="gap-2">
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
					GitHub
				</Button>
			</a>
		</div>
	</section>
</BaseLayout>
