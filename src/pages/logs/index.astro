---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { LogTimeline } from "../../components/islands/LogTimeline";
import { getCollection } from "astro:content";
import { marked } from "marked";

const logs = await getCollection("logs");
const sortedLogs = logs.sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// Derive all unique tags from actual content
const allTags = [...new Set(sortedLogs.flatMap((l) => l.data.tags))].sort();

// Generate a deterministic commit hash from id + date
function fakeHash(input: string): string {
    let hash = 0;
    for (let i = 0; i < input.length; i++) {
        const ch = input.charCodeAt(i);
        hash = ((hash << 5) - hash) + ch;
        hash |= 0;
    }
    return Math.abs(hash).toString(16).padStart(7, '0').slice(0, 7);
}

// Short plain-text description for collapsed state
function getDescription(log: typeof sortedLogs[number]): string {
    const body = log.body ?? '';
    const lines = body.split('\n').filter(l => l.trim() && !l.startsWith('```') && !l.startsWith('#'));
    return lines[0]?.trim().slice(0, 200) ?? log.data.title;
}

// Rendered markdown overview for expanded state (first ~800 chars of body prose)
function getOverviewHtml(log: typeof sortedLogs[number]): string {
    const body = log.body ?? '';
    // Strip frontmatter-like lines, keep first meaningful portion
    const lines = body.split('\n');
    // Collect lines until we hit ~800 chars, skipping nothing (keep code blocks, lists, etc.)
    let charCount = 0;
    const selected: string[] = [];
    for (const line of lines) {
        if (charCount > 800) break;
        selected.push(line);
        charCount += line.length;
    }
    const overviewMd = selected.join('\n').trim();
    if (!overviewMd) return `<p>${log.data.title}</p>`;
    return marked.parse(overviewMd, { async: false }) as string;
}

// Serialise logs for the island
const serialised = sortedLogs.map((log) => ({
    id: log.id,
    title: log.data.title,
    description: getDescription(log),
    overviewHtml: getOverviewHtml(log),
    type: log.data.type,
    tags: log.data.tags,
    mood: log.data.mood,
    hoursWorked: log.data.hoursWorked,
    pubDate: log.data.pubDate.toISOString(),
    href: `/logs/${log.id}`,
    commitHash: fakeHash(log.id + log.data.pubDate.toISOString()),
}));
---

<BaseLayout title="Engineering Logs | Harshit Sharma">
    <div class="container py-20 sm:py-32">
        <header class="mb-12">
            <h1
                class="text-3xl sm:text-5xl font-medium tracking-tight text-foreground mb-4"
            >
                Engineering Logs
            </h1>
            <p class="text-dim text-[15px] max-w-2xl leading-relaxed">
                Daily notes, architecture decisions, and deep dives.
            </p>
        </header>

        <LogTimeline
            client:load
            logs={serialised}
            allTags={allTags}
        />
    </div>
</BaseLayout>
