---
/**
 * Algorithm sub-page route.
 *
 * URL: /algorithms/{id}/{section}
 * e.g. /algorithms/1-two-sum/approach
 *
 * Renders a specific sub-page (approach, story, analysis, similar)
 * for an algorithm, with tab navigation back to the main page
 * and between sibling sub-pages.
 */
import { getCollection, render } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
    const notes = await getCollection("algorithmNotes");
    const algos = await getCollection("algorithms");

    return notes.map((note) => {
        const parentAlgo = algos.find(a => a.id === note.data.parentAlgo);
        // Find sibling notes for this algorithm
        const siblings = notes.filter(n => n.data.parentAlgo === note.data.parentAlgo);

        return {
            params: {
                id: note.data.parentAlgo,
                section: note.data.section,
            },
            props: { note, parentAlgo, siblings },
        };
    });
}

const { note, parentAlgo, siblings } = Astro.props;
const { Content } = await render(note);

const SECTION_LABELS: Record<string, string> = {
    approach: 'Approach',
    story: 'Story',
    analysis: 'Analysis',
    similar: 'Similar',
};

// Build tab list: Solution (main) + all available sub-pages
const tabs = [
    { label: 'Solution', href: `/algorithms/${note.data.parentAlgo}`, active: false },
    ...siblings
        .sort((a, b) => a.data.section.localeCompare(b.data.section))
        .map(s => ({
            label: SECTION_LABELS[s.data.section] ?? s.data.section,
            href: `/algorithms/${s.data.parentAlgo}/${s.data.section}`,
            active: s.data.section === note.data.section,
        })),
];
---

<BaseLayout title={`${note.data.title} | ${parentAlgo?.data.title ?? 'Algorithm'} | Harshit Sharma`}>
    <article class="container py-20 sm:py-32 max-w-4xl mx-auto">
        <!-- Back link -->
        <a
            href="/algorithms"
            class="inline-flex items-center gap-1.5 text-faint hover:text-dim text-sm mb-10 transition-colors"
        >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg> Back to Algorithms
        </a>

        <!-- Parent algorithm title -->
        <h1 class="text-2xl sm:text-4xl font-medium tracking-tight text-foreground mb-6">
            {parentAlgo?.data.title ?? note.data.parentAlgo}
        </h1>

        <!-- Tab Navigation -->
        <nav class="flex items-center gap-1 mb-10 border-b border-border overflow-x-auto scrollbar-none" aria-label="Algorithm sections">
            {tabs.map((tab) => (
                <a
                    href={tab.href}
                    class:list={[
                        "text-[13px] font-mono px-4 py-2.5 transition-colors whitespace-nowrap border-b-2 -mb-px",
                        tab.active
                            ? "text-foreground border-accent font-medium"
                            : "text-faint hover:text-dim border-transparent",
                    ]}
                    aria-current={tab.active ? "page" : undefined}
                >
                    {tab.label}
                </a>
            ))}
        </nav>

        <!-- Sub-page title -->
        <h2 class="text-xl sm:text-2xl font-medium text-foreground mb-8">
            {note.data.title}
        </h2>

        <!-- Markdown body -->
        <section class="prose prose-portfolio max-w-none algo-terminal">
            <Content />
        </section>
    </article>
</BaseLayout>
