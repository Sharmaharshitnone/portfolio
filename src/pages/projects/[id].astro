---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Badge from "../../components/ui/Badge.astro";
import { generateProjectSchema } from "../../lib/seo";
export async function getStaticPaths() {
    const projects = await getCollection("projects");
    return projects.map((project) => ({
        params: { id: project.id },
        props: { project },
    }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const difficultyColors = {
    easy: "#3fb950",
    medium: "#d29922",
    hard: "#f85149",
};

const projectSchema = generateProjectSchema({
    title: project.data.title,
    description: project.data.description,
    category: project.data.category,
    githubUrl: project.data.githubUrl,
    liveUrl: project.data.liveUrl,
    techStack: project.data.techStack,
    pubDate: project.data.pubDate,
});
---

<BaseLayout title={`${project.data.title} | Harshit Sharma`} description={project.data.description}>
    <!-- JSON-LD: SoftwareApplication schema -->
    <script slot="head" type="application/ld+json" set:html={JSON.stringify(projectSchema)} />
    <article class="container py-20 sm:py-32">
        <!-- Back link -->
        <a
            href="/projects"
            class="inline-flex items-center gap-1.5 text-faint hover:text-dim text-sm mb-10 transition-colors"
        >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg> Back to Projects
        </a>

        <!-- Header -->
        <header class="mb-12">
            <div class="flex items-center gap-3 mb-4">
                <span class="text-xs font-mono text-dim uppercase tracking-wider">
                    {project.data.category}
                </span>
                {project.data.status && project.data.status !== "active" && (
                    <Badge variant="default">{project.data.status}</Badge>
                )}
            </div>

            <h1 class="text-3xl sm:text-5xl font-medium tracking-tight text-foreground mb-4">
                {project.data.title}
            </h1>

            <p class="text-dim text-[15px] max-w-2xl leading-relaxed mb-6">
                {project.data.description}
            </p>

            <!-- Tech stack -->
            <div class="flex flex-wrap gap-2 mb-6">
                {project.data.techStack.map((tech: string) => (
                    <Badge variant="default">{tech}</Badge>
                ))}
            </div>

            <!-- Links -->
            <div class="flex items-center gap-4">
                <a
                    href={project.data.githubUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-dim hover:text-subtle text-[13px] inline-flex items-center gap-1.5 transition-colors"
                >
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg> Source
                </a>
                {project.data.liveUrl && (
                    <a
                        href={project.data.liveUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-dim hover:text-subtle text-[13px] inline-flex items-center gap-1.5 transition-colors"
                    >
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg> Live Demo
                    </a>
                )}
            </div>
        </header>

        <!-- Case study sections (if present) -->
        {project.data.problem && (
            <section class="mb-10">
                <h2 class="text-foreground font-medium text-lg mb-3">Problem</h2>
                <p class="text-dim text-[15px] leading-relaxed">{project.data.problem}</p>
            </section>
        )}

        {project.data.solution && (
            <section class="mb-10">
                <h2 class="text-foreground font-medium text-lg mb-3">Solution</h2>
                <p class="text-dim text-[15px] leading-relaxed">{project.data.solution}</p>
            </section>
        )}

        {project.data.challenges && project.data.challenges.length > 0 && (
            <section class="mb-10">
                <h2 class="text-foreground font-medium text-lg mb-3">Challenges</h2>
                <ul class="list-disc list-inside text-dim text-[15px] leading-relaxed space-y-1">
                    {project.data.challenges.map((c: string) => <li>{c}</li>)}
                </ul>
            </section>
        )}

        {project.data.outcomes && project.data.outcomes.length > 0 && (
            <section class="mb-10">
                <h2 class="text-foreground font-medium text-lg mb-3">Outcomes</h2>
                <ul class="list-disc list-inside text-dim text-[15px] leading-relaxed space-y-1">
                    {project.data.outcomes.map((o: string) => <li>{o}</li>)}
                </ul>
            </section>
        )}

        <!-- Markdown body -->
        <section class="prose prose-portfolio max-w-none">
            <Content />
        </section>
    </article>
</BaseLayout>
