---
import { ThemeToggle } from "../components/islands/ThemeToggle";
import Navbar from "../components/global/Navbar.astro";
import Footer from "../components/global/Footer.astro";
import BaseHead from "../components/global/BaseHead.astro";
import "../styles/global.css";

interface Props {
    title: string;
    description?: string;
    /** Per-page OG image override (absolute URL) */
    ogImage?: string;
}

const {
    title,
    description = "Senior Backend & Systems Engineer specializing in Rust, Go, and distributed systems.",
    ogImage,
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
    <head>
        <BaseHead title={title} description={description} ogImage={ogImage}>
            <slot name="head" />
        </BaseHead>
    </head>

    <body
        class="bg-background text-foreground font-sans antialiased min-h-screen flex flex-col"
    >
        <!-- Skip-to-content: WCAG 2.4.1 -->
        <a
            href="#main-content"
            class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[100] focus:px-4 focus:py-2 focus:bg-foreground focus:text-background focus:rounded-md focus:text-sm focus:font-medium"
        >
            Skip to content
        </a>

        <!-- Sentinel for IntersectionObserver to detect scroll state without binding to scroll events -->
        <div
            id="nav-sentinel"
            class="absolute top-0 left-0 w-full h-2 pointer-events-none select-none"
            aria-hidden="true"
        >
        </div>

        <!--
          Header: Navbar (.astro shell) + ThemeToggle (Preact island, sibling).
        -->
        <div class="relative">
            <Navbar />
            <!-- ThemeToggle: right-14 on mobile (clears hamburger), right-8 on desktop -->
            <div class="fixed top-0 right-14 md:right-8 h-14 flex items-center z-[51]">
                <ThemeToggle client:load />
            </div>
        </div>

        <main id="main-content" class="flex-1">
            <slot />
        </main>

        <Footer />
    </body>
</html>
