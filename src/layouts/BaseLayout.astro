---
import { ThemeToggle } from "../components/islands/ThemeToggle";
import { SearchBar } from "../components/islands/SearchBar";
import { HexToggle } from "../components/islands/HexToggle";
import { HexOverlay } from "../components/islands/HexOverlay";
import Navbar from "../components/global/Navbar.astro";
import Footer from "../components/global/Footer.astro";
import BaseHead from "../components/global/BaseHead.astro";
import { getCollection } from "astro:content";
import "../styles/global.css";

interface Props {
    title: string;
    description?: string;
    /** Per-page OG image override (absolute URL) */
    ogImage?: string;
}

const {
    title,
    description = "Senior Backend & Systems Engineer specializing in Rust, Go, and distributed systems.",
    ogImage,
} = Astro.props;

// ── Build search index at build time ──────────────────────
const [logs, algorithms, projects] = await Promise.all([
    getCollection("logs"),
    getCollection("algorithms"),
    getCollection("projects"),
]);

const searchItems = [
    ...projects.map(p => ({
        id: p.id,
        title: p.data.title,
        type: 'project' as const,
        tags: p.data.techStack,
        href: `/projects/${p.id}`,
        meta: `${p.data.category} · ${p.data.techStack.join(', ')}`,
    })),
    ...algorithms.map(a => ({
        id: a.id,
        title: a.data.title,
        type: 'algorithm' as const,
        tags: a.data.tags,
        href: `/algorithms/${a.id}`,
        meta: `${a.data.platform} · ${a.data.difficulty} · ${a.data.tags.join(', ')}`,
    })),
    ...logs.map(l => ({
        id: l.id,
        title: l.data.title,
        type: 'log' as const,
        tags: l.data.tags,
        href: `/logs/${l.id}`,
        meta: `${l.data.type} · ${l.data.tags.join(', ')}`,
    })),
];
---

<!doctype html>
<html lang="en" class="scroll-smooth">
    <head>
        <BaseHead title={title} description={description} ogImage={ogImage}>
            <slot name="head" />
        </BaseHead>
    </head>

    <body
        class="bg-background text-foreground font-sans antialiased min-h-screen flex flex-col"
    >
        <!-- Skip-to-content: WCAG 2.4.1 -->
        <a
            href="#main-content"
            class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[100] focus:px-4 focus:py-2 focus:bg-foreground focus:text-background focus:rounded-md focus:text-sm focus:font-medium"
        >
            Skip to content
        </a>

        <!-- Fixed navbar + controls -->
        <Navbar>
            <Fragment slot="nav-right">
                <SearchBar client:load transition:persist items={searchItems} />
                <HexToggle client:load transition:persist />
                <ThemeToggle client:load transition:persist />
            </Fragment>
        </Navbar>
        <!-- Spacer for fixed header height -->
        <div class="h-14" aria-hidden="true"></div>

        <main id="main-content" class="flex-1">
            <slot />
        </main>

        <Footer />

        <!-- Hex dump overlay — renders nothing when mode === 'ui' -->
        <HexOverlay client:idle />
    </body>
</html>
