# Environment Variables
# Copy this file to .env and fill in your values.
# Reference: 12-Factor App — Factor III (Config)

# ── Site Configuration ──
SITE_URL=https://harshit.systems

# ── Backend: Appwrite (contact forms, view counters, analytics) ──
# Get these from: https://cloud.appwrite.io/console
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your-project-id-here

# ── Feature Flags ──
ANALYTICS_ENABLED=false

# ── Engineering Pulse (Build-time data) ──
# Optional: Remove variables to use mock data
GITHUB_TOKEN=your-github-token-here
GITHUB_USERNAME=your-github-username-here
LEETCODE_USERNAME=your-leetcode-username-here
CODEFORCES_HANDLE=your-codeforces-handle-here
